---
import BaseLayout from '../layouts/BaseLayout.astro';
const { default: FuerWenContent } = await import('../content/fuer-wen.md');
const { default: FuerWenNichtContent } = await import('../content/fuer-wen-nicht.md');
const { default: UeberMichContent } = await import('../content/ueber-mich.md');
---

<BaseLayout title="Mario Wochner – Transformationsprozesse">

  <!-- Hero / Startseite -->
  <section id="start" class="hero-section">
    <p class="hero-text">Schon wieder aufgewacht. 3&nbsp;Uhr 33. Warum...?</p>
  </section>

  <!-- Für wen das ist -->
  <section id="fuer-wen" class="page-section">
    <FuerWenContent />
  </section>

  <!-- Für wen das nichts ist -->
  <section id="fuer-wen-nicht" class="page-section">
    <FuerWenNichtContent />
  </section>

  <!-- Mein Angebot (Platzhalter) -->
  <section id="angebot" class="page-section page-section--placeholder">
  </section>

  <!-- Über mich -->
  <section id="ueber-mich" class="page-section">
    <UeberMichContent />
  </section>

  <!-- Kontakt -->
  <section id="kontakt" class="page-section page-section--last">
    <p>Sind Sie mitten in einem Veränderungsprozess? Sprechen wir.</p>
    <p><a href="mailto:mario@example.com">mario@example.com</a></p>
  </section>

</BaseLayout>
