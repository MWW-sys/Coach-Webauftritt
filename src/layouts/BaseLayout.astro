---
const {
  title = 'Mario Wochner'
} = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
      }

      body {
        background: #0a0e1a;
        color: #e8e4dc;
        font-family: 'Lora', Georgia, serif;
        font-size: 1.25rem;
        line-height: 1.8;
        min-height: 100vh;
        overflow-y: auto;
      }

      /* ─── Hamburger button ─── */
      #hamburger-btn {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 100;
        background: rgba(10, 14, 26, 0.85);
        border: 1px solid rgba(232, 228, 220, 0.2);
        color: #e8e4dc;
        font-size: 1.25rem;
        width: 42px;
        height: 42px;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        line-height: 1;
      }

      #hamburger-btn:hover {
        background: rgba(10, 14, 26, 1);
      }

      /* ─── Navigation ─── */
      nav {
        position: fixed;
        top: 68px;
        right: 0;
        z-index: 99;
        background: rgba(10, 14, 26, 0.98);
        border-left: 1px solid rgba(232, 228, 220, 0.12);
        border-bottom: 1px solid rgba(232, 228, 220, 0.12);
        min-width: 220px;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
      }

      #hamburger-btn:hover + nav,
      nav:hover,
      nav.open {
        max-height: 400px;
      }

      nav ul {
        list-style: none;
        padding: 0.5rem 0;
      }

      nav li {
        border-bottom: 1px solid rgba(232, 228, 220, 0.07);
      }

      nav li:last-child {
        border-bottom: none;
      }

      nav a {
        display: block;
        padding: 0.75rem 1.5rem;
        color: #e8e4dc;
        text-decoration: none;
        font-family: 'Lora', Georgia, serif;
        font-size: 0.95rem;
        font-weight: 400;
      }

      nav a:hover {
        background: rgba(232, 228, 220, 0.07);
      }

      /* ─── Main container ─── */
      main {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* ─── Hero section (index page only) ─── */
      :global(.hero-section) {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 0 2rem;
      }

      :global(.hero-text) {
        font-size: 1.75rem;
        font-weight: 400;
        font-style: italic;
        letter-spacing: 0.03em;
        line-height: 1.6;
        color: #e8e4dc;
        max-width: 600px;
      }

      /* ─── One-pager body content ─── */
      :global(.page-content) {
        padding: 5rem 2cm 8rem;
      }

      :global(.page-content p) {
        max-width: 620px;
        margin-bottom: 1.3rem;
        color: #e8e4dc;
        font-size: 1.25rem;
        line-height: 1.8;
      }

      /* Make anchor spans invisible and not affect flow */
      :global(.page-content span[id]) {
        display: block;
        visibility: hidden;
        height: 0;
        overflow: hidden;
      }

      /* ─── Subpage content ─── */
      :global(.subpage-content) {
        padding: 6rem 2cm 6rem;
      }

      :global(.subpage-content p) {
        max-width: 620px;
        margin-bottom: 1.1rem;
        font-size: 1.1rem;
        line-height: 1.75;
        color: #e8e4dc;
      }

      :global(.subpage-content h1) {
        font-size: 1.5rem;
        font-weight: 500;
        color: rgb(201, 174, 123);
        margin-bottom: 1.8rem;
        max-width: 620px;
      }

      :global(.subpage-content a) {
        color: rgb(201, 174, 123);
      }

      :global(.subpage-content a:hover) {
        text-decoration: underline;
      }

      /* ─── Mobile ─── */
      @media (max-width: 768px) {
        body {
          font-size: 1.1rem;
        }

        nav {
          left: 0;
          right: 0;
          min-width: unset;
          border-left: none;
        }

        :global(.hero-text) {
          font-size: 1.35rem;
        }

        :global(.page-content) {
          padding: 4rem 1.5rem 6rem;
        }

        :global(.page-content p) {
          font-size: 1.1rem;
        }

        :global(.subpage-content) {
          padding: 6rem 1.5rem 5rem;
        }
      }
    </style>
  </head>

  <body>
    <button id="hamburger-btn" aria-label="Menü">☰</button>
    <nav id="nav-menu">
      <ul>
        <li><a href="/#about">Über mich</a></li>
        <li><a href="/#contact">Kontakt</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <script>
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const navMenu = document.getElementById('nav-menu');
      const navLinks = navMenu.querySelectorAll('a');
      let menuTimeout;

      // Desktop: open on hover
      hamburgerBtn.addEventListener('mouseenter', () => {
        clearTimeout(menuTimeout);
        navMenu.classList.add('open');
      });

      hamburgerBtn.addEventListener('mouseleave', () => {
        menuTimeout = setTimeout(() => navMenu.classList.remove('open'), 300);
      });

      navMenu.addEventListener('mouseenter', () => {
        clearTimeout(menuTimeout);
        navMenu.classList.add('open');
      });

      navMenu.addEventListener('mouseleave', () => {
        menuTimeout = setTimeout(() => navMenu.classList.remove('open'), 300);
      });

      // Close when clicking a link
      navLinks.forEach(link => {
        link.addEventListener('click', () => navMenu.classList.remove('open'));
      });

      // Mobile: toggle on tap
      hamburgerBtn.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
          e.stopPropagation();
          navMenu.classList.toggle('open');
        }
      });

      // Close when clicking outside
      document.addEventListener('click', (e) => {
        if (!navMenu.contains(e.target) && !hamburgerBtn.contains(e.target)) {
          navMenu.classList.remove('open');
        }
      });
    </script>
  </body>
</html>
