---
const {
  title = 'Meine Seite',
  backgroundImage = '/images/background.jpg'
} = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles/global.css" />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: 'Georgia', 'Garamond', serif;
        font-size: 1.25rem;
        line-height: 1.7;
        color: rgb(245, 240, 232);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overflow-y: auto;
        scroll-padding-top: 80px;
        background: #0a0e1a;
        background-image: url("/images/background.jpg");
        background-size: cover;
        background-attachment: fixed;
        background-blend-mode: multiply;
        opacity: 1;
      }

      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #0a0e1a;
        opacity: 0.85;
        z-index: -1;
      }

      #background-video {
        display: none;
      }

      #hamburger-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 100;
        background: rgba(10, 14, 26, 0.75);
        border: 1px solid rgba(245, 240, 232, 0.25);
        color: rgb(245, 240, 232);
        font-size: 1.4rem;
        width: 44px;
        height: 44px;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.2s;
      }

      #hamburger-btn:hover {
        background: rgba(10, 14, 26, 1);
      }

      nav {
        position: fixed;
        top: 70px;
        right: 0;
        z-index: 99;
        background: rgba(10, 14, 26, 0.95);
        border-left: 1px solid rgba(245, 240, 232, 0.15);
        border-bottom: 1px solid rgba(245, 240, 232, 0.15);
        min-width: 220px;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
      }

      nav.open {
        max-height: 400px;
      }

      nav ul {
        display: flex;
        flex-direction: column;
        gap: 0;
        list-style: none;
        margin: 0;
        padding: 0.5rem 0;
      }

      nav li {
        padding: 0;
        border-bottom: 1px solid rgba(245, 240, 232, 0.08);
      }

      nav li:last-child {
        border-bottom: none;
      }

      nav a {
        display: block;
        padding: 0.75rem 1.5rem;
        color: rgb(245, 232, 218);
        text-decoration: none;
        font-weight: normal;
        font-size: 1rem;
      }

      nav a:hover {
        background: rgba(245, 240, 232, 0.08);
      }

      main {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding: 40vh 2cm 60px 2cm;
        max-width: 52vw;
      }

      :global(main p) {
        max-width: 100%;
        text-align: justify;
        line-height: 1.85;
        margin-bottom: 1.1rem;
      }

      h1, h2, h3 {
        color: rgb(201, 174, 123);
        margin-bottom: 1rem;
      }

      #unmute-btn {
        position: fixed;
        bottom: 1.5cm;
        right: 1.5cm;
        z-index: 100;
        background: rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(245, 240, 232, 0.4);
        color: rgb(245, 240, 232);
        border-radius: 50%;
        width: 48px;
        height: 48px;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
      }

      #unmute-btn:hover {
        background: rgba(0, 0, 0, 0.7);
      }

      /* ── Mobil-Layout (bis 768px) ── */
      @media (max-width: 768px) {
        body {
          overflow-y: auto;
          background: #0a0e1a;
          background-image: none;
          font-size: 1.1rem;
        }

        body::before {
          display: none;
        }

        nav {
          left: 0;
          right: 0;
          min-width: unset;
          border-left: none;
        }

        main {
          max-width: 100%;
          padding: 35vh 1.5cm 80px 1.5cm;
        }

        :global(main p) {
          text-align: left;
        }
      }
    </style>
  </head>

  <body>
    <button id="hamburger-btn" aria-label="Menü">☰</button>
    <nav id="nav-menu">
      <ul>
        <li><a href="/">Startseite</a></li>
        <li><a href="/fuer-wen">Für wen das ist</a></li>
        <li><a href="/about">Über mich</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <script>
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const navMenu = document.getElementById('nav-menu');
      const navLinks = navMenu.querySelectorAll('a');

      // Toggle menu
      hamburgerBtn.addEventListener('click', () => {
        navMenu.classList.toggle('open');
      });

      // Close menu when link is clicked
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('open');
        });
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!navMenu.contains(e.target) && !hamburgerBtn.contains(e.target)) {
          navMenu.classList.remove('open');
        }
      });
    </script>
  </body>
</html>